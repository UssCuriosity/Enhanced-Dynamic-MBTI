generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  password  String
  createdAt DateTime   @default(now())
  plans     TestPlan[]
}

model TestPlan {
  id           String         @id @default(cuid())
  userId       String
  durationDays Int            @default(14)
  currentDay   Int            @default(0)
  status       String         @default("active") // active | completed | paused
  startDate    DateTime       @default(now())
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions     DailySession[]
  boundary     BoundaryModel?

  @@index([userId])
}

model DailySession {
  id          String      @id @default(cuid())
  planId      String
  dayNumber   Int
  completedAt DateTime    @default(now())
  contextNote String?
  plan        TestPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  answers     Answer[]
  score       DailyScore?

  @@unique([planId, dayNumber])
  @@index([planId])
}

model Answer {
  id         String       @id @default(cuid())
  sessionId  String
  questionId String
  value      Int
  dimension  String       // NS | TF | JP | EI
  session    DailySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model DailyScore {
  id        String       @id @default(cuid())
  sessionId String       @unique
  nsScore   Float
  tfScore   Float
  jpScore   Float
  eiScore   Float
  session   DailySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model BoundaryModel {
  id                  String   @id @default(cuid())
  planId              String   @unique
  convexHullVertices  String   // JSON string
  ellipsoidParams     String   // JSON string
  centroid            String   // JSON string
  stats               String   // JSON string
  createdAt           DateTime @default(now())
  plan                TestPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}
